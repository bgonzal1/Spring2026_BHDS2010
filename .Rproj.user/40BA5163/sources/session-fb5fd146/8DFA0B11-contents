#Another approach
# Wilcoxon Rank-Sum Test (for independent samples)
#wilcox.test(group1, group2, exact = TRUE, correct = FALSE)
 #correct = TRUE applies continuity correction to improve approximation
names(wide_bookhappy)

happyModelmedians <- wilcox.test(wide_bookhappy$Book.1, wide_bookhappy$Book2, data = wide_bookhappy)


#to account for the ties - forces normal approximation (since ties prevent exact calculations)
