#We can also calculate the effect size. First type the following function given below:
  rFromWilcox<-function(wilcoxModel, N){
    z<- qnorm(wilcoxModel$p.value/2)
    r<- z/ sqrt(N)
    cat(wilcoxModel$data.name, "Effect Size, r = ", r)
  }

  #Then we call in the effect size function by specifying the model name and the
  #number of observations in our data.
rFromWilcox(happyModelmedians2, 20)






